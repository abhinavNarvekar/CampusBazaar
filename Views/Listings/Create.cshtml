@model ECommerceMVC.Models.Listing

@{
    ViewData["Title"] = "Create Listing";
}


<style>
.text-danger {
    font-size: 0.9rem;
    margin-top: 4px;
}</style>

<div class="row">
    <div class="col-8 offset-2">

        <h3>Create a new Listing</h3>

      <form asp-controller="Listings"
      asp-action="Create"
      method="post"
      enctype="multipart/form-data">

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label class="form-label">Title</label>
        <input asp-for="Title" class="form-control" placeholder="Enter a title" required />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" placeholder="Enter description" required></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Image URL</label>
       <input type="file" name="imageFile" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Price</label>
      <input asp-for="Price" type="number" step="0.01" class="form-control" required />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <button class="btn btn-dark">Add</button>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

    </div>
</div>